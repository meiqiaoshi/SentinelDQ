{
  "source": {
    "type": "duckdb",
    "path": ":memory:",
    "create_demo_tables": true
  },
  "datasets": [
    {
      "name": "public.orders",
      "freshness_column": "updated_at",
      "checks": {
        "freshness_minutes": 30,
        "volume_change_pct": 0.30,
        "volume_min_history": 3
      }
    },
    {
      "name": "public.users",
      "freshness_column": "updated_at",
      "checks": {
        "freshness_minutes": 120
      }
    }
  ]
}
