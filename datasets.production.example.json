{
  "source": {
    "type": "duckdb",
    "path": "./warehouse.duckdb",
    "create_demo_tables": false
  },
  "datasets": [
    {
      "name": "public.orders",
      "freshness_column": "updated_at",
      "checks": {
        "freshness_minutes": 60,
        "volume_change_pct": 0.30,
        "volume_min_history": 3,
        "schema_drift": true
      }
    },
    {
      "name": "public.users",
      "freshness_column": "updated_at",
      "checks": {
        "freshness_minutes": 120
      }
    }
  ]
}
